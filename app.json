{
  "expo": {
    "name": "Eco-Ed",
    "slug": "capstone-prototype",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/eco-ed-logo.png",
    "scheme": "eco-ed",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.happymukande.capstoneprototype"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1bbe3e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.happymukande.capstoneprototype"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/eco-ed-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Eco-Ed to choose a profile photo from your library.",
          "cameraPermission": "Allow Eco-Ed to take a profile photo with your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d40d0518-6699-4bd0-b847-3fb43135b2f6"
      },
      "EXPO_PUBLIC_SUPABASE_URL": "https://yxlhhzhejackrrylrehz.supabase.co",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_tsX9CI7RqvycEO3rmMmURQ_2rx6tYY4",
      "EXPO_PUBLIC_DISABLE_BACKEND": "false"
    },
    "owner": "happymukande",
    "updates": {
      "url": "https://u.expo.dev/d40d0518-6699-4bd0-b847-3fb43135b2f6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
